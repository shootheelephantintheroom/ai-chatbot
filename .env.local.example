# Copy this file to .env.local and fill in your keys.
# Both keys are read server-side only (in Next.js route handlers / scripts)
# and are never exposed to the browser.

# Anthropic — used for the streaming chat completions (model: claude-sonnet-4-6)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI — used for RAG embeddings (model: voyage-3.5)
VOYAGE_API_KEY=pa-...
